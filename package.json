{
  "name": "eisbachwelle",
  "version": "0.1.0",
  "description": "Nicht-kommerzielle PWA zur Anzeige des Zustands der Eisbachwelle in München (Abfluss, Pegel, Wasser- und Lufttemperatur).",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.4",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "chart.js": "4.5.1"
  }
}
